# Nomad server + client node — generated by Ansible
# DO NOT EDIT MANUALLY

datacenter = "{{ nomad_datacenter }}"
region     = "{{ nomad_region }}"
data_dir   = "{{ nomad_data_dir }}"
bind_addr  = "0.0.0.0"
log_level  = "INFO"

server {
  enabled          = true
  bootstrap_expect = {{ groups['nomad_servers'] | length }}
}

client {
  enabled = true

  meta {
    # Vault job is pinned to this node — see vault.nomad.hcl constraint
    vault_server = "true"
  }

  options = {
    "driver.raw_exec.enable" = "1"
  }
}

advertise {
  http = "{{ nomad_advertise_ip }}"
  rpc  = "{{ nomad_advertise_ip }}"
  serf = "{{ nomad_advertise_ip }}"
}

tls {
  http = true
  rpc  = true

  ca_file   = "{{ nomad_config_dir }}/nomad-agent-ca.pem"
  cert_file = "{{ nomad_config_dir }}/global-server-nomad.pem"
  key_file  = "{{ nomad_config_dir }}/global-server-nomad-key.pem"

  verify_server_hostname = true
}

plugin "docker" {
  config {
    allow_privileged = true
  }
}

acl {
  enabled = true
}

consul {
  address = "127.0.0.1:8500"
}
