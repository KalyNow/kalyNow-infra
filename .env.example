# ============================================================
# kalyNow Infrastructure – Environment Variables (example)
# Copy this file to .env and fill in the values before
# running docker compose.
# ============================================================

# ---- Traefik ---------------------------------------------------
TRAEFIK_DASHBOARD_PORT=8080

# ---- PostgreSQL ------------------------------------------------
POSTGRES_DB=kalyNow
POSTGRES_USER=kalyNow
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# ---- Redis -----------------------------------------------------
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# ---- MongoDB ---------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=kalyNow
MONGO_INITDB_ROOT_PASSWORD=changeme
MONGO_PORT=27017

# ---- Kafka -----------------------------------------------------
KAFKA_PORT=9092
KAFKA_CONTROLLER_PORT=9093

# ---- MinIO -----------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---- ClickHouse ------------------------------------------------
CLICKHOUSE_DB=kalyNow
CLICKHOUSE_USER=kalyNow
CLICKHOUSE_PASSWORD=changeme
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9004

# ---- Nomad -----------------------------------------------------
NOMAD_HTTP_PORT=4646
